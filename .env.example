# SQLite (default local dev — no Postgres required). DB file is created in the cwd when you start uvicorn (usually repo root).
DATABASE_URL=sqlite+pysqlite:///./wiki_trending_agent.db

# Local Postgres (start a server first, or use: docker compose up postgres)
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/wiki_trending_agent

SERPER_API_KEY=
WIKIMEDIA_ENTERPRISE_USERNAME=
WIKIMEDIA_ENTERPRISE_PASSWORD=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
BACKEND_BASE_URL=http://localhost:8000
